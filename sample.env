# ── Arc API (YouTube only) ────────────────────────────────────────────────────
# Arc API is used exclusively for YouTube downloads (job-based flow + DB cache)
# Get credentials from @smaugxd or deadlinetech.site
API_URL=https://api.arcmusic.fun
API_KEY=

# ── Fallen API (all other platforms) ─────────────────────────────────────────
# Used for Spotify, Apple Music, SoundCloud, Deezer, JioSaavn, Tidal, etc.
API_URL2=https://api.onegrab.fun
API_KEY2=

# ── Media DB cache (YouTube channel cache) ────────────────────────────────────
# DB_URI: MongoDB connection string for the arcapi.medias collection
DB_URI=
# MEDIA_CHANNEL_ID: Telegram channel ID where media files are cached (e.g. -1001234567890)
MEDIA_CHANNEL_ID=

# ── Bot settings ──────────────────────────────────────────────────────────────
SONG_DURATION_LIMIT=3600
OWNER_ID=
LOGGER_ID=
DEFAULT_SERVICE=youtube
DOWNLOADS_DIR=
DB_NAME=MusicBot
COOKIES_URL=
SUPPORT_GROUP=https://t.me/arcchatz
SUPPORT_CHANNEL=https://t.me/ArcUpdates
DEVS=
ENABLE_VPLAY=false
